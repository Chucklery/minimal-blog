<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1">
  <title>__TITLE__ — Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/vditor@3.10.8/dist/index.css" rel="stylesheet">
  <style>
    body{background:#f6f7f9}
    .editor-wrap{max-width:1080px;margin:20px auto;padding:0 16px}
    .meta-card{background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:16px;margin-bottom:14px;box-shadow:0 1px 2px rgba(0,0,0,.03)}
    .meta-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .meta-grid .full{grid-column:1 / -1}
    .title-input{font-size:1.55rem;font-weight:700}
    .editor{background:#fff;border:1px solid #e5e7eb;border-radius:10px;min-height:560px;overflow:hidden}
    .toast-box{position:fixed;bottom:24px;right:24px;z-index:9999}
    .toast-msg{background:#222;color:#fff;padding:10px 20px;border-radius:6px;margin-top:8px;font-size:0.9rem;animation:fadeIn .2s}
    .frontmatter-help{font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:.8rem;color:#6b7280;background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:10px;margin-top:10px;white-space:pre-wrap}
    @keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
    @media (max-width:760px){.meta-grid{grid-template-columns:1fr}}
  </style>
</head>
<body>
<nav class="navbar navbar-dark bg-dark px-3">
  <a class="navbar-brand" href="/admin/posts">← Posts</a>
  <div class="actions-nav d-flex gap-2">
    <button id="btn-draft" class="btn btn-sm btn-outline-light">Save Draft</button>
    <button id="btn-publish" class="btn btn-sm btn-light">Publish</button>
  </div>
</nav>

<div class="editor-wrap">
  <div class="meta-card">
    <div class="meta-grid">
      <div class="full">
        <label class="form-label small text-muted" for="title">Title</label>
        <input id="title" class="form-control title-input" placeholder="Post title..." value="__POST_TITLE__" autofocus>
      </div>
      <div>
        <label class="form-label small text-muted" for="slug">Slug</label>
        <input id="slug" class="form-control" placeholder="post-slug" value="__POST_SLUG__">
      </div>
      <div>
        <label class="form-label small text-muted" for="date">Date</label>
        <input id="date" class="form-control" type="date">
      </div>
      <div class="full">
        <label class="form-label small text-muted" for="description">Description</label>
        <textarea id="description" class="form-control" rows="2" placeholder="文章摘要，会写入 frontmatter description"></textarea>
      </div>
      <div class="full">
        <label class="form-label small text-muted" for="tags">Tags</label>
        <input id="tags" class="form-control" placeholder="文章tag，记得加逗号">
      </div>
      <div class="form-check">
        <input id="draft" class="form-check-input" type="checkbox">
        <label class="form-check-label" for="draft">draft</label>
      </div>
      <div class="form-check">
        <input id="featured" class="form-check-input" type="checkbox">
        <label class="form-check-label" for="featured">featured</label>
      </div>
      <div id="meta-timestamps" class="full" style="display:flex;gap:24px;font-size:.8rem;color:#9ca3af">
        <span>Created: <strong id="created-display">—</strong></span>
        <span>Updated: <strong id="updated-display">—</strong></span>
      </div>
    </div>
    <div class="frontmatter-help" id="frontmatter-preview"></div>
  </div>

  <div id="editor" class="editor"></div>
  <div id="toasts" class="toast-box"></div>
</div>

<script src="https://cdn.jsdelivr.net/npm/vditor@3.10.8/dist/index.min.js"></script>
<script src="/admin/editor/editor.js"></script>
</body>
</html>
