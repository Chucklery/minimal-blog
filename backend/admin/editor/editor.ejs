<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1">
  <title>__TITLE__ — Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/vditor@3.10.8/dist/index.css" rel="stylesheet">
  <style>
    :root {
      --bg:#f8f9fa;
      --surface:#fff;
      --border:#e5e7eb;
      --text:#1f2937;
      --muted:#6b7280;
      --accent:#111827;
      --radius:10px;
    }
    *{box-sizing:border-box}
    body{background:var(--bg);color:var(--text);font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif}
    .editor-wrap{
      display:flex;
      gap:16px;
      max-width:1400px;
      margin:20px auto;
      padding:0 20px;
      align-items:flex-start;
    }
    .meta-card{
      background:var(--surface);
      border:1px solid var(--border);
      border-radius:var(--radius);
      padding:20px;
      width:340px;
      flex-shrink:0;
      position:sticky;
      top:20px;
      max-height:calc(100vh - 40px);
      overflow-y:auto;
      box-shadow:0 1px 3px rgba(0,0,0,.04);
    }
    .meta-card::-webkit-scrollbar{width:4px}
    .meta-card::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
    .meta-grid{display:flex;flex-direction:column;gap:14px}
    .meta-grid label{font-size:.75rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px;display:block}
    .meta-grid input,
    .meta-grid textarea{
      width:100%;
      border:1px solid var(--border);
      border-radius:6px;
      padding:8px 10px;
      font-size:.875rem;
      font-family:inherit;
      color:var(--text);
      background:var(--bg);
      outline:none;
      transition:border-color .15s;
    }
    .meta-grid input:focus,
    .meta-grid textarea:focus{border-color:var(--accent)}
    .meta-grid textarea{resize:vertical;min-height:52px}
    .title-input{font-size:1rem!important;font-weight:600}
    .form-check{display:flex;align-items:center;gap:8px;font-size:.85rem}
    .form-check-input{width:16px!important;height:16px;accent-color:var(--accent);flex-shrink:0}
    .meta-divider{height:1px;background:var(--border);margin:2px 0}
    .editor{
      flex:1;
      min-width:0;
      background:var(--surface);
      border:1px solid var(--border);
      border-radius:var(--radius);
      min-height:calc(100vh - 40px);
      overflow:hidden;
      box-shadow:0 1px 3px rgba(0,0,0,.04);
    }
    .toast-box{position:fixed;bottom:24px;right:24px;z-index:9999}
    .toast-msg{background:#1f2937;color:#fff;padding:10px 18px;border-radius:8px;margin-top:8px;font-size:.85rem;animation:fadeIn .2s;box-shadow:0 4px 12px rgba(0,0,0,.15)}
    .frontmatter-help{
      font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
      font-size:.72rem;
      color:var(--muted);
      background:#f9fafb;
      border:1px solid var(--border);
      border-radius:6px;
      padding:10px;
      margin-top:14px;
      white-space:pre-wrap;
      max-height:160px;
      overflow-y:auto;
    }
    @keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
    @media (max-width:860px){
      .editor-wrap{flex-direction:column;padding:0 12px}
      .meta-card{width:100%;position:static;max-height:none}
      .editor{min-height:60vh}
    }
  </style>
</head>
<body>
<nav class="navbar navbar-dark bg-dark px-3">
  <a class="navbar-brand" href="/admin/posts">← Posts</a>
  <div class="actions-nav d-flex gap-2">
    <button id="btn-draft" class="btn btn-sm btn-outline-light">Save Draft</button>
    <button id="btn-publish" class="btn btn-sm btn-light">Publish</button>
  </div>
</nav>

<div class="editor-wrap">
  <div class="meta-card">
    <div class="meta-grid">
      <div>
        <label for="title">Title</label>
        <input id="title" class="title-input" placeholder="Post title..." value="__POST_TITLE__" autofocus>
      </div>
      <div>
        <label for="slug">Slug</label>
        <input id="slug" placeholder="post-slug" value="__POST_SLUG__">
      </div>
      <div>
        <label for="date">Date</label>
        <input id="date" type="date">
      </div>
      <div>
        <label for="description">Description</label>
        <textarea id="description" rows="2" placeholder="write your description about this note..."></textarea>
      </div>
      <div>
        <label for="tags">Tags</label>
        <input id="tags" placeholder="tag1, tag2, ...">
      </div>
      <div class="form-check">
        <input id="draft" class="form-check-input" type="checkbox">
        <label for="draft">draft</label>
      </div>
      <div class="form-check">
        <input id="featured" class="form-check-input" type="checkbox">
        <label for="featured">featured</label>
      </div>
      <div id="meta-timestamps" style="display:flex;gap:16px;font-size:.75rem;color:var(--muted);padding-top:4px">
        <span>Created: <strong id="created-display">—</strong></span>
        <span>Updated: <strong id="updated-display">—</strong></span>
      </div>
    </div>
    <div class="frontmatter-help" id="frontmatter-preview"></div>
  </div>

  <div id="editor" class="editor"></div>
  <div id="toasts" class="toast-box"></div>
</div>

<script src="https://cdn.jsdelivr.net/npm/vditor@3.10.8/dist/index.min.js"></script>
<script src="/admin/editor/editor.js"></script>
</body>
</html>
