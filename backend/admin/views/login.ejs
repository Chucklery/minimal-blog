<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Login — Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>body{min-height:100vh;display:flex;align-items:center;background:#f5f5f5}.login-box{max-width:400px;margin:auto;padding:2rem;background:#fff;border-radius:8px;box-shadow:0 1px 3px rgba(0,0,0,.1)}</style>
</head>
<body>
<div class="login-box">
  <h4 class="text-center mb-3">Chuckle's Blog</h4>
  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
  <form method="POST" action="/admin/login">
    <div class="mb-3"><input name="username" class="form-control" placeholder="Username" required autofocus></div>
    <div class="mb-3"><input name="password" type="password" class="form-control" placeholder="Password" required></div>
    <button class="btn btn-dark w-100">Login</button>
  </form>
</div>
</body>
</html>
