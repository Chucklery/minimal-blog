<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Dashboard — Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-dark bg-dark px-3">
  <a class="navbar-brand" href="/admin/dashboard">Dashboard</a>
  <div>
    <a href="/admin/posts" class="btn btn-sm btn-outline-light">Posts</a>
    <a href="/admin/media" class="btn btn-sm btn-outline-light">Media</a>
    <a href="/admin/settings" class="btn btn-sm btn-outline-light">Settings</a>
    <a href="http://localhost:8088" class="btn btn-sm btn-outline-light">View Site →</a>
  </div>
</nav>
<div class="container mt-5">
  <h3>Welcome, <%= user.username %></h3>
  <div class="row mt-4">
    <div class="col-md-4"><div class="card"><div class="card-body"><h2><%= posts.length %></h2><small class="text-muted">Total Posts</small></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><h2><%= posts.filter(p => p.status === 'published').length %></h2><small class="text-muted">Published</small></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><h2><%= media.length %></h2><small class="text-muted">Media Files</small></div></div></div>
  </div>
  <div class="mt-4"><a href="/admin/posts/new" class="btn btn-dark">+ New Post</a></div>
</div>
</body>
</html>
